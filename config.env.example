# AetherClaude Agent Configuration
# Copy this file to ~/.env and fill in your values.
# This file is sourced by run-agent.sh at startup.

# --- GitHub App ---
# Create a GitHub App at https://github.com/settings/apps
# Install it on both your upstream repo and your fork.
GITHUB_APP_ID=your-app-id-here

# --- Proxy (required for network isolation) ---
# tinyproxy runs on localhost:8888 with a domain allowlist.
# All agent traffic is routed through this proxy.
HTTPS_PROXY=http://127.0.0.1:8888
HTTP_PROXY=http://127.0.0.1:8888
NO_PROXY=localhost,127.0.0.1

# --- Webhook Secret ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Must match the secret configured in your GitHub App webhook settings.
WEBHOOK_SECRET=your-webhook-secret-here
